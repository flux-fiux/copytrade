# Root env for docker-compose.prod.yml — domains + web build-time public vars.
# Copy to .env and fill. (Per-service secrets live in apps/*/.env — see SELF-HOST.md.)

# ── Public domains (DNS A records → this server) ──────────────────────────────
APP_DOMAIN=app.yourdomain.com
API_DOMAIN=api.yourdomain.com
WS_DOMAIN=ws.yourdomain.com

# ── Web build-time (NEXT_PUBLIC_* are baked into the bundle at build) ──────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=https://ws.yourdomain.com
NEXT_PUBLIC_SITE_URL=https://app.yourdomain.com
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
