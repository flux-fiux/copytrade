# ── MetaAPI Cloud ────────────────────────────────────────────────────────────
# Get from https://app.metaapi.cloud → API access
METAAPI_TOKEN=

# ── Internal API ─────────────────────────────────────────────────────────────
# Must match INTERNAL_API_TOKEN in apps/api/.env  (never commit the real value)
API_URL=https://api-service.up.railway.app
INTERNAL_API_TOKEN=change-me-to-match-api-service

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=rediss://default:[password]@[host].upstash.io:6379

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
