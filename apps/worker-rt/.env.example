# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=rediss://default:[password]@[host].upstash.io:6379

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://your-domain.vercel.app

# ── Internal API (for market quote broadcaster) ───────────────────────────────
INTERNAL_API_URL=https://api-service.up.railway.app

# ── Market Broadcaster ────────────────────────────────────────────────────────
# How often to push price quotes to subscribed clients (milliseconds)
QUOTE_POLL_MS=5000

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
