# Single-domain, path-based routing + automatic HTTPS.
# Requires: A record for $APP_DOMAIN → server IP, ports 80+443 open.
#   /api/*        → FastAPI (keeps the /api/v1 prefix)
#   /socket.io/*  → Socket.IO realtime (websocket upgrade handled automatically)
#   everything else → Next.js web

{$APP_DOMAIN} {
	encode zstd gzip

	handle /api/* {
		reverse_proxy api:8000
	}

	handle /socket.io/* {
		reverse_proxy worker-rt:3001
	}

	handle {
		reverse_proxy web:3000
	}
}
